{
    "name": "ylab/php-migrater",
    "description": "PHP Legacy Migration Orchestrator — analyze, test, and fix PHP 5.x–8.x codebases for modern PHP versions",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "keywords": ["php", "migration", "upgrade", "legacy", "rector", "compatibility", "refactoring"],
    "authors": [
        {
            "name": "Ytsoni",
            "homepage": "https://github.com/ytsoni"
        }
    ],
    "require": {
        "php": ">=8.1",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^6.0|^7.0",
        "symfony/finder": "^6.0|^7.0",
        "symfony/process": "^6.0|^7.0",
        "sebastian/diff": "^5.0|^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "phpstan/phpstan": "^1.0"
    },
    "suggest": {
        "rector/rector": "Required for automated Rector-based fixes (recommended)",
        "phpcompatibility/php-compatibility": "Required for PHPCompatibility-based analysis"
    },
    "autoload": {
        "psr-4": {
            "Ylab\\PhpMigrater\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ylab\\PhpMigrater\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/php-migrater"
    ],
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyze src/ --level=8"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
